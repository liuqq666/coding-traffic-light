#!/bin/sh
''':'
PYTHON="${CODEX_PYTHON:-}"
if [ -z "$PYTHON" ]; then
  CODEX_BUNDLED_PYTHON="$HOME/.cache/codex-runtimes/codex-primary-runtime/dependencies/python/bin/python3"
  if [ -x "$CODEX_BUNDLED_PYTHON" ]; then
    PYTHON="$CODEX_BUNDLED_PYTHON"
  else
    PYTHON="python3"
  fi
fi
exec "$PYTHON" "$0" "$@"
':'''
import json
import os
import shutil
import subprocess
import sys
from datetime import datetime
from pathlib import Path
from typing import List


SCRIPT_DIR = Path(__file__).resolve().parent
LIGHT = os.environ.get("CODEX_LIGHT_PATH") or str(SCRIPT_DIR / "codex-light")
if not os.path.exists(LIGHT):
    LIGHT = shutil.which("codex-light") or LIGHT
LIGHT_LABEL = "com.liuqq666.codex-status-light"
LIGHT_APP = Path.home() / "Library" / "Application Support" / "CodexStatusLight" / "CodexStatusLight"
STATE_PATH = Path.home() / "Library" / "Application Support" / "CodexStatusLight" / "state.json"
LOG_PATH = Path.home() / "Library" / "Application Support" / "CodexStatusLight" / "hook.log"


def log(message: str) -> None:
    try:
        LOG_PATH.parent.mkdir(parents=True, exist_ok=True)
        with LOG_PATH.open("a", encoding="utf-8") as handle:
            handle.write(f"{datetime.now().isoformat(timespec='seconds')} {message}\n")
    except Exception:
        pass


def status_light_running() -> bool:
    pgrep = shutil.which("pgrep") or "/usr/bin/pgrep"
    try:
        result = subprocess.run([pgrep, "-x", "CodexStatusLight"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        return result.returncode == 0
    except Exception:
        return False


def ensure_status_light_running() -> None:
    if status_light_running():
        return

    uid = os.getuid()
    launchctl = shutil.which("launchctl") or "/bin/launchctl"
    try:
        result = subprocess.run(
            [launchctl, "kickstart", "-k", f"gui/{uid}/{LIGHT_LABEL}"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            timeout=2,
            check=False,
        )
        if result.returncode == 0:
            log("ensure-running launchctl")
            return
    except Exception as exc:
        log(f"ensure-running launchctl-failed {exc}")

    if status_light_running():
        return

    if LIGHT_APP.exists() and os.access(LIGHT_APP, os.X_OK):
        try:
            subprocess.Popen([str(LIGHT_APP)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, start_new_session=True)
            log("ensure-running direct")
        except Exception as exc:
            log(f"ensure-running direct-failed {exc}")


def read_event() -> dict:
    raw = sys.stdin.read()
    if not raw.strip():
        return {}
    try:
        return json.loads(raw)
    except Exception as exc:
        log(f"invalid-json {exc}")
        return {}


def session_id(event: dict) -> str:
    for key in ("session_id", "thread_id", "conversation_id", "task_id"):
        value = event.get(key)
        if value:
            return str(value)
    for key in ("CODEX_SESSION_ID", "CODEX_THREAD_ID", "CODEX_CONVERSATION_ID", "CODEX_TASK_ID"):
        value = os.environ.get(key)
        if value:
            return value
    cwd = event.get("cwd") or os.environ.get("PWD") or "unknown"
    return f"hook:{cwd}"


def compact(value: object, limit: int = 180) -> str:
    if value is None:
        return ""
    if isinstance(value, (dict, list)):
        text = json.dumps(value, ensure_ascii=False, separators=(",", ":"))
    else:
        text = str(value)
    text = " ".join(text.split())
    if len(text) > limit:
        return text[: limit - 1] + "…"
    return text


def preview_for_event(event: dict, name: str) -> str:
    if name == "UserPromptSubmit":
        return compact(event.get("prompt"), 180)
    if name == "PreToolUse":
        tool_name = compact(event.get("tool_name"), 40)
        tool_input = compact(event.get("tool_input"), 140)
        return compact(f"{tool_name}: {tool_input}" if tool_name else tool_input, 180)
    if name == "PermissionRequest":
        return compact(event.get("message") or event.get("reason") or event.get("tool_input") or "需要确认", 180)
    if name in {"Stop", "SubagentStop"}:
        return compact(event.get("last_assistant_message"), 180)
    return compact(event, 180)


def title_for_event(event: dict, name: str) -> str:
    prompt = compact(event.get("prompt"), 54)
    if prompt:
        return prompt
    cwd = compact(event.get("cwd") or os.environ.get("PWD"), 160)
    if cwd:
        return Path(cwd).name or cwd
    tool_name = compact(event.get("tool_name"), 54)
    if tool_name:
        return tool_name
    return compact(session_id(event), 54)


def metadata_args(event: dict, name: str) -> List[str]:
    values = {
        "title": title_for_event(event, name),
        "cwd": compact(event.get("cwd") or os.environ.get("PWD"), 300),
        "preview": preview_for_event(event, name),
        "source-event": name,
        "tool-name": compact(event.get("tool_name"), 80),
        "turn-id": compact(event.get("turn_id"), 120),
        "transcript-path": compact(event.get("transcript_path"), 300),
        "model": compact(event.get("model"), 80),
    }
    args: List[str] = []
    for key, value in values.items():
        if value:
            args.extend([f"--{key}", value])
    return args


def set_light(state: str, event: dict) -> None:
    try:
        args = [LIGHT, state, "--session", session_id(event), *metadata_args(event, name)]
        subprocess.run(args, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        log(f"set {state}")
    except Exception as exc:
        log(f"set-failed {state} {exc}")


event = read_event()
name = event.get("hook_event_name") or (sys.argv[1] if len(sys.argv) > 1 else "")
log(f"event {name} session={session_id(event)} keys={','.join(sorted(event.keys()))}")
ensure_status_light_running()

if name in {"UserPromptSubmit", "PreToolUse"}:
    set_light("working", event)
elif name == "PermissionRequest":
    set_light("waiting", event)
elif name in {"Stop", "SubagentStop"}:
    set_light("done", event)

print("{}")
