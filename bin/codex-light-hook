#!/bin/sh
''':'
PYTHON="${CODEX_PYTHON:-}"
if [ -z "$PYTHON" ]; then
  CODEX_BUNDLED_PYTHON="$HOME/.cache/codex-runtimes/codex-primary-runtime/dependencies/python/bin/python3"
  if [ -x "$CODEX_BUNDLED_PYTHON" ]; then
    PYTHON="$CODEX_BUNDLED_PYTHON"
  else
    PYTHON="python3"
  fi
fi
exec "$PYTHON" "$0" "$@"
':'''
import json
import os
import re
import shutil
import subprocess
import sys
from datetime import datetime
from pathlib import Path


SCRIPT_DIR = Path(__file__).resolve().parent
LIGHT = os.environ.get("CODEX_LIGHT_PATH") or str(SCRIPT_DIR / "codex-light")
if not os.path.exists(LIGHT):
    LIGHT = shutil.which("codex-light") or LIGHT
STATE_PATH = Path.home() / "Library" / "Application Support" / "CodexStatusLight" / "state.json"
LOG_PATH = Path.home() / "Library" / "Application Support" / "CodexStatusLight" / "hook.log"


def log(message: str) -> None:
    try:
        LOG_PATH.parent.mkdir(parents=True, exist_ok=True)
        with LOG_PATH.open("a", encoding="utf-8") as handle:
            handle.write(f"{datetime.now().isoformat(timespec='seconds')} {message}\n")
    except Exception:
        pass


def read_event() -> dict:
    raw = sys.stdin.read()
    if not raw.strip():
        return {}
    try:
        return json.loads(raw)
    except Exception as exc:
        log(f"invalid-json {exc}")
        return {}


def session_id(event: dict) -> str:
    for key in ("session_id", "thread_id", "conversation_id", "task_id"):
        value = event.get(key)
        if value:
            return str(value)
    for key in ("CODEX_SESSION_ID", "CODEX_THREAD_ID", "CODEX_CONVERSATION_ID", "CODEX_TASK_ID"):
        value = os.environ.get(key)
        if value:
            return value
    cwd = event.get("cwd") or os.environ.get("PWD") or "unknown"
    return f"hook:{cwd}"


def set_light(state: str, event: dict) -> None:
    try:
        subprocess.run([LIGHT, state, "--session", session_id(event)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        log(f"set {state}")
    except Exception as exc:
        log(f"set-failed {state} {exc}")


def looks_waiting(message: str) -> bool:
    if not message:
        return False
    patterns = [
        r"等你",
        r"需要你",
        r"需要.*?(回复|确认|授权|登录|验证码|文件|截图|选择|提供|补充)",
        r"请.*?(回复|确认|授权|登录|提供|发我|补充|选择)",
        r"你.*?(确认|选择|提供|发我|补充).*?吗",
        r"要不要|可以吗|行不行|是否",
        r"我需要.*?(你|确认|授权|文件|截图|验证码)",
        r"blocked|waiting for user|permission|approval",
        r"\?",
        r"？",
    ]
    return any(re.search(pattern, message, re.IGNORECASE | re.DOTALL) for pattern in patterns)


event = read_event()
name = event.get("hook_event_name") or (sys.argv[1] if len(sys.argv) > 1 else "")
log(f"event {name} session={session_id(event)} keys={','.join(sorted(event.keys()))}")

if name in {"UserPromptSubmit", "PreToolUse"}:
    set_light("working", event)
elif name == "PermissionRequest":
    set_light("waiting", event)
elif name in {"Stop", "SubagentStop"}:
    message = event.get("last_assistant_message") or ""
    session = session_id(event)
    if looks_waiting(message):
        subprocess.run([LIGHT, "waiting", "--session", session], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        log("set waiting")
    else:
        subprocess.run([LIGHT, "done", "--session", session], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        log("set done")

print("{}")
