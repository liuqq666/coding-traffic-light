#!/bin/sh
''':'
PYTHON="${CODEX_PYTHON:-}"
if [ -z "$PYTHON" ]; then
  CODEX_BUNDLED_PYTHON="$HOME/.cache/codex-runtimes/codex-primary-runtime/dependencies/python/bin/python3"
  if [ -x "$CODEX_BUNDLED_PYTHON" ]; then PYTHON="$CODEX_BUNDLED_PYTHON"; else PYTHON="python3"; fi
fi
exec "$PYTHON" "$0" "$@"
':'''
"""Command helper for Codex Status Light."""

import argparse
import json
import os
import sqlite3
import time
from pathlib import Path

STATE_FILE = Path.home() / "Library" / "Application Support" / "CodexStatusLight" / "state.json"
PREFERENCES_FILE = Path.home() / "Library" / "Application Support" / "CodexStatusLight" / "preferences.json"
CODEX_HOME = Path.home() / ".codex"
CODEX_STATE_DB = CODEX_HOME / "state_5.sqlite"
CODEX_SESSIONS_DIR = CODEX_HOME / "sessions"
CODEX_ARCHIVED_SESSIONS_DIR = CODEX_HOME / "archived_sessions"
STATES = {"working", "done", "waiting", "idle"}
COMMANDS = {"quit", "show", "reset-position", "clear-sessions", "settings"}
PRIORITY = {"waiting": 3, "done": 2, "working": 1, "idle": 0}
DEFAULT_SESSION_STALE_SECONDS = 6 * 60 * 60
RATE_LIMIT_RECENT_FILE_LIMIT = 20
RATE_LIMIT_RECENT_MAX_AGE_SECONDS = 12 * 60 * 60
METADATA_KEYS = ("title", "cwd", "preview", "source_event", "tool_name", "turn_id", "transcript_path", "model")
RATE_LIMIT_KEYS = (
    "rate_limit_primary_used_percent",
    "rate_limit_primary_remaining_percent",
    "rate_limit_primary_window_minutes",
    "rate_limit_primary_resets_at",
    "rate_limit_name",
    "rate_limit_plan_type",
)


def ensure_runtime() -> None:
    STATE_FILE.parent.mkdir(parents=True, exist_ok=True)


def read_json(path: Path) -> dict:
    try:
        value = json.loads(path.read_text(encoding="utf-8"))
        return value if isinstance(value, dict) else {}
    except Exception:
        return {}


def atomic_write(path: Path, payload: dict) -> None:
    ensure_runtime()
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text(json.dumps(payload, ensure_ascii=False, indent=2, sort_keys=True), encoding="utf-8")
    tmp.replace(path)


def pref_number(key: str, default: float) -> float:
    try:
        return float(read_json(PREFERENCES_FILE).get(key, default))
    except Exception:
        return default


def session_stale_seconds() -> float:
    return max(60.0, pref_number("session_stale_seconds", DEFAULT_SESSION_STALE_SECONDS))


def session_from_env() -> str | None:
    for key in ("CODEX_SESSION_ID", "CODEX_THREAD_ID", "CODEX_CONVERSATION_ID", "CODEX_TASK_ID"):
        value = os.environ.get(key)
        if value:
            return value
    return None


def is_uuid(value: object) -> bool:
    if not isinstance(value, str) or len(value) != 36:
        return False
    for index, char in enumerate(value):
        if index in {8, 13, 18, 23}:
            if char != "-":
                return False
        elif char.lower() not in "0123456789abcdef":
            return False
    return True


def dir_has_session(directory: Path, session_id: str) -> bool:
    try:
        return any(session_id in item.name for item in directory.iterdir())
    except Exception:
        return False


def sqlite_archived(session_id: str) -> bool | None:
    if not CODEX_STATE_DB.exists():
        return None
    try:
        with sqlite3.connect(f"file:{CODEX_STATE_DB}?mode=ro", uri=True, timeout=0.2) as connection:
            row = connection.execute("SELECT archived FROM threads WHERE id = ? LIMIT 1", (session_id,)).fetchone()
    except Exception:
        return None
    return None if row is None else bool(row[0])


def openable(session_id: str, item: dict) -> bool:
    if not is_uuid(session_id):
        return False
    if dir_has_session(CODEX_ARCHIVED_SESSIONS_DIR, session_id):
        return False
    archived = sqlite_archived(session_id)
    if archived is not None:
        return not archived
    transcript = item.get("transcript_path")
    if isinstance(transcript, str) and "/.codex/sessions/" in transcript and Path(transcript).exists():
        return True
    return dir_has_session(CODEX_SESSIONS_DIR, session_id)


def compact(value: object, limit: int = 300) -> str | None:
    if value is None:
        return None
    text = json.dumps(value, ensure_ascii=False, separators=(",", ":")) if isinstance(value, (dict, list)) else str(value)
    text = " ".join(text.split())
    if not text:
        return None
    return text[: limit - 1] + "…" if len(text) > limit else text


def number(value: object) -> float | None:
    if value is None:
        return None
    try:
        return float(value)
    except Exception:
        return None


def latest_token_count_payload(path: Path) -> dict | None:
    try:
        with path.open("r", encoding="utf-8", errors="ignore") as handle:
            latest = None
            for line in handle:
                if '"token_count"' not in line:
                    continue
                try:
                    event = json.loads(line)
                except Exception:
                    continue
                payload = event.get("payload")
                if isinstance(payload, dict) and payload.get("type") == "token_count":
                    latest = payload
    except Exception:
        return None
    return latest if isinstance(latest, dict) else None


def quota_metadata_from_token_count(payload: dict) -> dict:
    rate_limits = payload.get("rate_limits")
    if not isinstance(rate_limits, dict):
        return {}
    primary = rate_limits.get("primary")
    if not isinstance(primary, dict):
        return {}

    out = {}
    used = number(primary.get("used_percent"))
    if used is not None:
        used = min(max(used, 0.0), 100.0)
        out["rate_limit_primary_used_percent"] = used
        out["rate_limit_primary_remaining_percent"] = min(max(100.0 - used, 0.0), 100.0)

    window = number(primary.get("window_minutes"))
    if window is not None:
        out["rate_limit_primary_window_minutes"] = window

    resets_at = number(primary.get("resets_at"))
    if resets_at is not None:
        out["rate_limit_primary_resets_at"] = resets_at

    limit_name = compact(rate_limits.get("limit_name"), 120)
    if limit_name:
        out["rate_limit_name"] = limit_name
    plan_type = compact(rate_limits.get("plan_type"), 40)
    if plan_type:
        out["rate_limit_plan_type"] = plan_type
    return out


def quota_metadata_from_path(path: Path) -> dict:
    if not path.exists() or not path.is_file():
        return {}
    payload = latest_token_count_payload(path)
    if not payload:
        return {}
    return quota_metadata_from_token_count(payload)


def recent_transcript_paths(preferred_path: object) -> list[Path]:
    paths: list[tuple[float, Path]] = []
    seen: set[str] = set()

    def add_path(path: Path) -> None:
        try:
            resolved = str(path.expanduser().resolve())
            stat = path.stat()
        except Exception:
            return
        if resolved in seen or not path.is_file():
            return
        seen.add(resolved)
        paths.append((stat.st_mtime, path))

    if isinstance(preferred_path, str) and preferred_path:
        add_path(Path(preferred_path))

    if CODEX_SESSIONS_DIR.exists():
        cutoff = time.time() - RATE_LIMIT_RECENT_MAX_AGE_SECONDS
        try:
            for path in CODEX_SESSIONS_DIR.rglob("*.jsonl"):
                try:
                    if path.stat().st_mtime < cutoff:
                        continue
                except Exception:
                    continue
                add_path(path)
        except Exception:
            pass

    paths.sort(key=lambda item: item[0], reverse=True)
    return [path for _, path in paths[:RATE_LIMIT_RECENT_FILE_LIMIT]]


def active_five_hour_quota(meta: dict) -> bool:
    resets_at = number(meta.get("rate_limit_primary_resets_at"))
    if resets_at is None or resets_at <= time.time():
        return False
    window = number(meta.get("rate_limit_primary_window_minutes"))
    return window is None or 295 <= window <= 305


def best_quota_metadata(candidates: list[dict]) -> dict:
    usable = [candidate for candidate in candidates if candidate]
    if not usable:
        return {}
    active = [candidate for candidate in usable if active_five_hour_quota(candidate)]
    pool = active or usable

    def score(meta: dict) -> tuple[float, float, float]:
        remaining = number(meta.get("rate_limit_primary_remaining_percent"))
        used = number(meta.get("rate_limit_primary_used_percent"))
        resets_at = number(meta.get("rate_limit_primary_resets_at"))
        return (
            remaining if remaining is not None else 101.0,
            -(used if used is not None else -1.0),
            -(resets_at if resets_at is not None else 0.0),
        )

    return min(pool, key=score)


def latest_quota_metadata(transcript_path: object) -> dict:
    candidates = [quota_metadata_from_path(path) for path in recent_transcript_paths(transcript_path)]
    return best_quota_metadata(candidates)


def metadata(args: argparse.Namespace) -> dict:
    out = {}
    for key in METADATA_KEYS:
        value = compact(getattr(args, key, None), 300 if key in {"cwd", "transcript_path"} else 180)
        if value:
            out[key] = value
    out.update(latest_quota_metadata(getattr(args, "transcript_path", None)))
    return out


def apply_quota_metadata(payload: dict, meta: dict) -> None:
    if not any(key in meta for key in RATE_LIMIT_KEYS[:4]):
        return
    changed = False
    for key in RATE_LIMIT_KEYS:
        if key in meta:
            payload[key] = meta[key]
            changed = True
        elif key in {"rate_limit_name", "rate_limit_plan_type"} and key in payload:
            payload.pop(key, None)
            changed = True
    if changed:
        payload["rate_limit_updated_at"] = time.time()


def candidate_state(now: float, session_id: str, item: object) -> str | None:
    if not isinstance(item, dict) or not openable(session_id, item):
        return None
    state = item.get("state")
    if state not in STATES:
        return None
    updated_at = float(item.get("updated_at") or 0)
    acknowledged_at = float(item.get("acknowledged_at") or 0)
    if state == "working":
        return "working" if now - updated_at <= session_stale_seconds() else None
    if state in {"done", "waiting"}:
        return state if acknowledged_at < updated_at else None
    return None


def aggregate(payload: dict) -> str:
    now = time.time()
    sessions = payload.get("sessions")
    states = []
    manual = payload.get("manual_state")
    if manual in STATES:
        states.append(manual)
    elif not isinstance(sessions, dict) and payload.get("state") in STATES:
        states.append(payload["state"])
    if isinstance(sessions, dict):
        for session_id, item in sessions.items():
            state = candidate_state(now, session_id, item)
            if state:
                states.append(state)
    return max(states, key=lambda value: PRIORITY[value]) if states else "idle"


def write_state(state: str, session_id: str | None, meta: dict) -> None:
    if meta.get("source_event") in {"Stop", "SubagentStop"}:
        state = "done"
    if state not in STATES:
        raise SystemExit(f"Unknown state: {state}")
    payload = read_json(STATE_FILE)
    now = time.time()
    apply_quota_metadata(payload, meta)
    if session_id:
        payload.pop("manual_state", None)
        sessions = payload.get("sessions")
        sessions = sessions if isinstance(sessions, dict) else {}
        if state == "idle":
            sessions.pop(session_id, None)
        else:
            item = sessions.get(session_id) if isinstance(sessions.get(session_id), dict) else {}
            item.update({"id": session_id, "state": state, "updated_at": now, **meta})
            sessions[session_id] = item
        payload["sessions"] = sessions
        payload["state"] = aggregate(payload)
    else:
        payload["manual_state"] = state
        payload["sessions"] = {}
        payload["state"] = state
    payload["updated_at"] = now
    payload.pop("command", None)
    atomic_write(STATE_FILE, payload)


def write_command(command: str) -> None:
    payload = read_json(STATE_FILE)
    payload["command"] = command
    payload["updated_at"] = time.time()
    if command == "clear-sessions":
        payload["sessions"] = {}
    payload["state"] = "quit" if command == "quit" else aggregate(payload)
    atomic_write(STATE_FILE, payload)


def reset_position() -> None:
    prefs = read_json(PREFERENCES_FILE)
    prefs.pop("window_x", None)
    prefs.pop("window_y", None)
    prefs["updated_at"] = time.time()
    atomic_write(PREFERENCES_FILE, prefs)


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Codex Status Light command helper")
    parser.add_argument("command", choices=[*sorted(STATES), *sorted(COMMANDS), "status"])
    parser.add_argument("--session")
    for key in METADATA_KEYS:
        parser.add_argument("--" + key.replace("_", "-"), dest=key)
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    if args.command == "status":
        print(aggregate(read_json(STATE_FILE)))
        return 0
    if args.command in COMMANDS:
        if args.command == "reset-position":
            reset_position()
        write_command(args.command)
        print(args.command)
        return 0
    write_state(args.command, args.session or session_from_env(), metadata(args))
    print(args.command)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
